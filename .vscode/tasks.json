{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Raytrace: Build and Render",
            "command": "clang++",
            "args": [
                "-std=c++11",
                "-O3",
                "main.cpp",
                "-o",
                "main",
                "&&",
                "./main",
                ">",
                "image.ppm"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": false
            }
        }
    ]
}